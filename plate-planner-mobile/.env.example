# PlatePlanner Mobile - Environment Variables
# Copy this file to .env and update values for your local setup.
# See: https://docs.expo.dev/guides/environment-variables/

# Backend API base URL (no trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:8000

# Google OAuth redirect URI
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:8081/google-callback.html
