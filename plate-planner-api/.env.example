# ===========================================================================
#  PlatePlanner API -- Environment Variables
# ===========================================================================
#
# Copy this file to .env and fill in your values.
#
# For LOCAL development (Docker Compose), the defaults below should work.
# For CLOUD deployment (Neon + AuraDB), replace the placeholders marked
# with <...> angle brackets.
#
# ===========================================================================

# ---------------------------------------------------------------------------
# PostgreSQL  (Relational database)
# ---------------------------------------------------------------------------
# LOCAL  (Docker Compose):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plateplanner
#
# CLOUD  (Neon Postgres):
#   Get your connection string from https://console.neon.tech
#   Neon requires SSL. The app will auto-append ?sslmode=require.
#   DATABASE_URL=postgresql://<user>:<password>@<endpoint>.neon.tech/plateplanner
#
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plateplanner

# ---------------------------------------------------------------------------
# Neo4j  (Graph database for recipe/ingredient substitution)
# ---------------------------------------------------------------------------
# LOCAL  (Docker Compose):
#   NEO4J_URI=bolt://localhost:7687
#   NEO4J_USER=neo4j
#   NEO4J_PASSWORD=12345678
#
# CLOUD  (Neo4j AuraDB):
#   Get your connection URI from https://console.neo4j.io
#   AuraDB requires neo4j+s:// (TLS encrypted). The app detects this
#   automatically and enables encrypted=True + system CA trust.
#   NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
#   NEO4J_USER=neo4j
#   NEO4J_PASSWORD=<your-auradb-password>
#
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# ---------------------------------------------------------------------------
# JWT / Authentication
# ---------------------------------------------------------------------------
# IMPORTANT: Change SECRET_KEY in production!
SECRET_KEY=dev-fixed-secret-change-in-prod-aabbccddeeff00112233445566778899
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ---------------------------------------------------------------------------
# For local dev: use "*" to allow all origins.
# For production: comma-separated list of allowed origins.
#   CORS_ORIGINS=https://plateplanner.vercel.app,https://www.plateplanner.com
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# External Recipe APIs
# ---------------------------------------------------------------------------
# Get a free key at https://spoonacular.com/food-api
SPOONACULAR_API_KEY=<your-spoonacular-api-key>

# ---------------------------------------------------------------------------
# LLM / AI Configuration  (for AI Assistant and recipe generation)
# ---------------------------------------------------------------------------
# Set one or more API keys. The app auto-detects which provider to use.
# LLM_PROVIDER can be left empty for auto-detection, or set to:
#   "google", "openai", or "ollama"
LLM_PROVIDER=
GOOGLE_API_KEY=<your-google-api-key>
GOOGLE_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---------------------------------------------------------------------------
# USDA Nutrition API  (for ingredient nutrition lookups)
# ---------------------------------------------------------------------------
# Get a free key at https://fdc.nal.usda.gov/api-key-signup
USDA_API_KEY=<your-usda-api-key>

# ---------------------------------------------------------------------------
# Vercel Blob Storage  (for user meal photo uploads)
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=<your-vercel-blob-token>

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8000
